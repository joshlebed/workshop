STAGE=local
DATABASE_URL=postgres://postgres:postgres@localhost:5432/workshop
SESSION_SECRET=change_me_generate_with_openssl_rand_hex_32_at_least_32_chars
AWS_REGION=us-east-1
LOG_LEVEL=debug
PORT=8787

# Spotify Web API app credentials (Client Credentials flow). Used by the
# Album Shelf feature to read public playlists. Register an app at
# https://developer.spotify.com/dashboard.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Sentry DSN for the backend project. Empty in local dev = SDK is a no-op.
# In prod, populated from SSM (set with: aws ssm put-parameter --name /workshop-prod/sentry_dsn --type SecureString --value '<dsn>' --overwrite).
SENTRY_DSN=
