STAGE=local
DATABASE_URL=postgres://postgres:postgres@localhost:5432/workshop
SESSION_SECRET=change_me_generate_with_openssl_rand_hex_32_at_least_32_chars
AWS_REGION=us-east-1
LOG_LEVEL=debug
PORT=8787

# Spotify OAuth — register an app at https://developer.spotify.com/dashboard
# Add `http://localhost:8787/v1/spotify/auth/callback` as a Redirect URI.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8787/v1/spotify/auth/callback
# Where the backend bounces the user back to after callback. On web this is the
# Expo dev server origin; on iOS use the `workshop://` deep link.
SPOTIFY_APP_REDIRECT_URI=http://localhost:8081
