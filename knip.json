{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.{sh,ts,mjs,js}"],
      "ignoreDependencies": ["concurrently"]
    },
    "apps/backend": {
      "entry": ["src/lambda.ts"]
    },
    "apps/workshop": {
      "entry": ["app/**/*.{ts,tsx}", "src/**/*.{ts,tsx}"],
      "ignoreBinaries": ["eas"],
      "ignoreDependencies": ["@react-navigation/native"]
    },
    "packages/*": {}
  }
}
